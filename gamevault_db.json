    "title": "Neon Collector Demo",
    "description": "Một trò chơi mẫu được tạo tự động để kiểm thử hệ thống. Sử dụng Canvas API và tương tác chuột.",
    "htmlContent": "\n<!DOCTYPE html>\n<html>\n<head>\n    <style>\n        body { margin: 0; overflow: hidden; background: #0f172a; font-family: sans-serif; }\n        canvas { display: block; }\n        #ui { position: absolute; top: 20px; left: 20px; color: white; pointer-events: none; }\n        h1 { margin: 0; font-size: 24px; text-shadow: 0 2px 4px rgba(0,0,0,0.5); }\n        p { margin: 5px 0; color: #94a3b8; }\n        #score { font-size: 40px; font-weight: bold; color: #fbbf24; }\n    </style>\n    <title>Neon Collector Demo</title>\n</head>\n<body>\n    <div id=\"ui\">\n        <h1>Neon Collector</h1>\n        <p>Di chuyển chuột để thu thập các hạt năng lượng!</p>\n        <div id=\"score\">0</div>\n    </div>\n    <canvas id=\"game\"></canvas>\n    <script>\n        const canvas = document.getElementById('game');\n        const ctx = canvas.getContext('2d');\n        const scoreEl = document.getElementById('score');\n        \n        let width, height;\n        let particles = [];\n        let player = { x: 0, y: 0, r: 20, color: '#6366f1' };\n        let score = 0;\n\n        function resize() {\n            width = canvas.width = window.innerWidth;\n            height = canvas.height = window.innerHeight;\n        }\n        window.addEventListener('resize', resize);\n        resize();\n\n        window.addEventListener('mousemove', (e) => {\n            player.x = e.clientX;\n            player.y = e.clientY;\n        });\n\n        class Particle {\n            constructor() {\n                this.x = Math.random() * width;\n                this.y = Math.random() * height;\n                this.vx = (Math.random() - 0.5) * 2;\n                this.vy = (Math.random() - 0.5) * 2;\n                this.r = Math.random() * 5 + 2;\n                this.color = `hsl(${Math.random() * 360}, 70%, 60%)`;\n            }\n            update() {\n                this.x += this.vx;\n                this.y += this.vy;\n                if (this.x < 0 || this.x > width) this.vx *= -1;\n                if (this.y < 0 || this.y > height) this.vy *= -1;\n                \n                // Collision\n                const dx = this.x - player.x;\n                const dy = this.y - player.y;\n                const dist = Math.sqrt(dx*dx + dy*dy);\n                if (dist < player.r + this.r) {\n                    this.reset();\n                    score += 10;\n                    scoreEl.innerText = score;\n                    // Pulse effect\n                    player.r = 30;\n                    setTimeout(() => player.r = 20, 100);\n                }\n            }\n            reset() {\n                this.x = Math.random() * width;\n                this.y = Math.random() * height;\n            }\n            draw() {\n                ctx.beginPath();\n                ctx.arc(this.x, this.y, this.r, 0, Math.PI * 2);\n                ctx.fillStyle = this.color;\n                ctx.fill();\n                ctx.shadowBlur = 10;\n                ctx.shadowColor = this.color;\n            }\n        }\n\n        for(let i=0; i<30; i++) particles.push(new Particle());\n\n        function loop() {\n            ctx.fillStyle = 'rgba(15, 23, 42, 0.2)'; // Trails\n            ctx.fillRect(0, 0, width, height);\n            \n            // Draw Player\n            ctx.beginPath();\n            ctx.arc(player.x, player.y, player.r, 0, Math.PI * 2);\n            ctx.fillStyle = player.color;\n            ctx.fill();\n            ctx.shadowBlur = 20;\n            ctx.shadowColor = player.color;\n\n            particles.forEach(p => {\n                p.update();\n                p.draw();\n            });\n            requestAnimationFrame(loop);\n        }\n        loop();\n    </script>\n</body>\n</html>\n      ",
